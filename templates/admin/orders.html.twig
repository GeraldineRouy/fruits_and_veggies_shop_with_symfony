{% extends 'base.html.twig' %}

{% block title %}Gestion des commandes - Administration{% endblock %}

{% block body %}
    <h1>Gestion des commandes</h1>

    {% if ordersData|length > 0 %}
        <table>
            <thead>
                <tr>
                    <th>N°</th>
                    <th>Client</th>
                    <th>Date</th>
                    <th>Statut</th>
                    <th>Total</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for orderData in ordersData %}
                    <tr>
                        <td>#{{ orderData.order.id }}</td>
                        <td>{{ orderData.order.user.email }}</td>
                        <td>{{ orderData.order.orderedAt|date('d/m/Y H:i') }}</td>
                        <td><span class="badge badge-{{ orderData.order.status.value }}">{{ status_labels[orderData.order.status.value] }}</span></td>
                        <td>{{ orderData.total|format_currency('EUR') }}</td>
                        <td><a href="{{ path('app_admin_order_detail', {id: orderData.order.id}) }}">Voir</a></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="pagination">
            {% if pagination.hasPrevious %}
                <a href="{{ path('app_admin_orders', {page: pagination.currentPage - 1}) }}">← Précédente</a>
            {% endif %}

            <span>Page {{ pagination.currentPage }} / {{ pagination.totalPages }}</span>

            {% if pagination.hasNext %}
                <a href="{{ path('app_admin_orders', {page: pagination.currentPage + 1}) }}">Suivante →</a>
            {% endif %}
        </div>
    {% else %}
        <p>Aucune commande pour le moment.</p>
    {% endif %}
{% endblock %}
