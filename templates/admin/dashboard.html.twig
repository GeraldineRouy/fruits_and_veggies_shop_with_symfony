    <div class="admin-cards">
        <div class="admin-card">
            <h2><a href="{{ path('app_admin_orders') }}">Commandes</a></h2>
            <p>Gérer les commandes clients</p>
        </div>

        <div class="admin-card">
            <h2><a href="{{ path('app_admin_users') }}">Utilisateurs</a></h2>
