{% extends 'base.html.twig' %}

{% block title %}Dashboard - Administration{% endblock %}

{% block body %}
    <h1 class="text-2xl font-bold text-gray-800 mb-6">Dashboard Administration</h1>

    <div class="admin-cards grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="{{ path('app_admin_orders') }}" class="admin-card bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6 border border-gray-100">
            <h2 class="text-lg font-semibold text-gray-800 mb-2">Commandes</h2>
            <p class="text-gray-600 text-sm">Gérer les commandes clients</p>
        </a>

        <a href="{{ path('app_admin_users') }}" class="admin-card bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6 border border-gray-100">
            <h2 class="text-lg font-semibold text-gray-800 mb-2">Utilisateurs</h2>
            <p class="text-gray-600 text-sm">Gérer les comptes utilisateurs</p>
        </a>

        <a href="{{ path('app_admin_categories') }}" class="admin-card bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6 border border-gray-100">
            <h2 class="text-lg font-semibold text-gray-800 mb-2">Catégories</h2>
            <p class="text-gray-600 text-sm">Gérer les catégories de produits</p>
        </a>

        <a href="{{ path('app_admin_products') }}" class="admin-card bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6 border border-gray-100">
            <h2 class="text-lg font-semibold text-gray-800 mb-2">Produits</h2>
            <p class="text-gray-600 text-sm">Gérer les produits du catalogue</p>
        </a>
    </div>
{% endblock %}
