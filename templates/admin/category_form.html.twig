{% extends 'base.html.twig' %}

{% block title %}{{ category.id ? 'Modifier' : 'Nouvelle' }} catégorie - Administration{% endblock %}

{% block body %}
    <h1>{{ category.id ? 'Modifier la catégorie' : 'Nouvelle catégorie' }}</h1>

    {{ form_start(form) }}
        {{ form_widget(form) }}
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="{{ path('app_admin_categories') }}" class="btn btn-link">Annuler</a>
    {{ form_end(form) }}
{% endblock %}
