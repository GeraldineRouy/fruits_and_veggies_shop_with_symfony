{% extends 'base.html.twig' %}

{% block title %}{{ category.id ? 'Modifier' : 'Nouvelle' }} catégorie - Administration{% endblock %}

{% block body %}
    <h1 class="text-2xl font-bold text-gray-800 mb-6">{{ category.id ? 'Modifier la catégorie' : 'Nouvelle catégorie' }}</h1>

    <div class="max-w-lg bg-white rounded-xl shadow-md p-6">
        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
            {{ form_widget(form) }}
            <div class="flex space-x-3 pt-4">
                <button type="submit" class="btn btn-primary bg-brand-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-brand-700 transition-colors">Enregistrer</button>
                <a href="{{ path('app_admin_categories') }}" class="btn btn-link px-4 py-2 text-gray-600 hover:text-gray-800 transition-colors">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
