{% extends 'base.html.twig' %}

{% block title %}{{ product.id ? 'Modifier' : 'Nouveau' }} produit - Administration{% endblock %}

{% block body %}
    <h1 class="text-2xl font-bold text-gray-800 mb-6">{{ product.id ? 'Modifier le produit' : 'Nouveau produit' }}</h1>

    <div class="max-w-lg bg-white rounded-xl shadow-md p-6">
        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
            {{ form_row(form.name) }}
            {{ form_row(form.description) }}
            {{ form_row(form.price) }}
            {{ form_row(form.image) }}
            {{ form_row(form.categories) }}

            <div class="flex space-x-3 pt-4">
                <button type="submit" class="btn btn-primary bg-brand-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-brand-700 transition-colors">Enregistrer</button>
                <a href="{{ path('app_admin_products') }}" class="btn btn-link px-4 py-2 text-gray-600 hover:text-gray-800 transition-colors">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
