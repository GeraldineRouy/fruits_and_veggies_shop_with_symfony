{% extends 'base.html.twig' %}

{% block title %}Email vérifié{% endblock %}

{% block body %}
<div class="max-w-md mx-auto mt-10">
    <div class="bg-white rounded-xl shadow-md p-8 text-center">
        <h1 class="text-2xl font-bold text-gray-800 mb-6">Email vérifié avec succès</h1>

        <p class="text-gray-600 mb-6">Votre adresse email a été vérifiée. Vous pouvez maintenant vous connecter.</p>

        <a href="{{ path('app_login') }}" class="btn btn-primary inline-block bg-brand-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-brand-700 transition-colors">Se connecter</a>
    </div>
</div>
{% endblock %}
