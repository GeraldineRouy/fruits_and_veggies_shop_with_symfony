{% extends 'base.html.twig' %}

{% block title %}Réinitialiser mon mot de passe{% endblock %}

{% block body %}
<div class="reset-password-container max-w-md mx-auto mt-10">
    <div class="bg-white rounded-xl shadow-md p-8">
        <h1 class="text-2xl font-bold text-gray-800 text-center mb-6">Réinitialiser mon mot de passe</h1>

        <p class="text-gray-600 text-sm mb-6">Choisissez un nouveau mot de passe.</p>

        {{ form_start(form, {action: path('app_reset_password', {token: token}), attr: {class: 'space-y-4'}}) }}
            {{ form_row(form.plainPassword) }}

            <button type="submit" class="btn btn-primary w-full bg-brand-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-brand-700 transition-colors">Réinitialiser mon mot de passe</button>
        {{ form_end(form) }}

        <p class="login-links mt-4 text-center text-sm text-gray-600">
            <a href="{{ path('app_login') }}" class="text-brand-600 hover:text-brand-800">Retour à la connexion</a>
        </p>
    </div>
</div>
{% endblock %}
