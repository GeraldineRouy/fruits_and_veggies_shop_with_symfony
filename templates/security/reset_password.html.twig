{% extends 'base.html.twig' %}

{% block title %}Réinitialiser mon mot de passe{% endblock %}

{% block body %}
<div class="reset-password-container">
    <h1>Réinitialiser mon mot de passe</h1>

    <p>Choisissez un nouveau mot de passe.</p>

    {% for label, messages in app.flashes(['error']) %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {{ form_start(form, {action: path('app_reset_password', {token: token})}) }}
        {{ form_row(form.plainPassword) }}

        <button type="submit" class="btn btn-primary">Réinitialiser mon mot de passe</button>
    {{ form_end(form) }}

    <p class="login-links">
        <a href="{{ path('app_login') }}">Retour à la connexion</a>
    </p>
</div>
{% endblock %}
