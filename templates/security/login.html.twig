{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="login-container max-w-md mx-auto mt-10">
    <div class="bg-white rounded-xl shadow-md p-8">
        <h1 class="text-2xl font-bold text-gray-800 text-center mb-6">Connexion</h1>

        {% if error %}
            <div class="alert alert-error bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form action="{{ path('app_login') }}" method="post">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group mb-4">
                <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" id="username" name="_username" value="{{ last_username }}" required autofocus class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-brand-500 focus:border-brand-500">
            </div>

            <div class="form-group mb-6">
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Mot de passe</label>
                <input type="password" id="password" name="_password" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-brand-500 focus:border-brand-500">
            </div>

            <button type="submit" class="btn btn-primary w-full bg-brand-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-brand-700 transition-colors">Se connecter</button>
        </form>

        <p class="login-links mt-4 text-center text-sm text-gray-600">
            <a href="{{ path('app_register') }}" class="text-brand-600 hover:text-brand-800">Créer un compte</a>
            <br>
            <a href="{{ path('app_forgot_password') }}" class="text-brand-600 hover:text-brand-800">Mot de passe oublié ?</a>
        </p>
    </div>
</div>
{% endblock %}
