{% if topProducts is not empty %}
    <section class="top-products mt-12">
        <h2 class="top-products__title text-2xl font-bold text-gray-800 mb-6">Top produits</h2>
        <div class="top-products-grid grid grid-cols-1 md:grid-cols-3 gap-6">
            {% for product in topProducts %}
                <a href="{{ path('app_shop_product', { id: product.id }) }}" class="top-product-card bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 overflow-hidden group">
                    <div class="relative">
                        <img src="{{ asset(product.image) }}" alt="{{ product.name }}" class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300">
                        <div class="absolute top-2 left-2 bg-yellow-400 text-yellow-900 text-xs font-bold rounded-full w-8 h-8 flex items-center justify-center shadow-md">
                            {{ loop.index }}
                        </div>
                    </div>
                    <div class="p-4">
                        <h3 class="text-lg font-semibold text-gray-800">{{ product.name }}</h3>
                        <p class="price text-xl font-bold text-brand-600 mt-1">{{ product.price }} €</p>
                    </div>
                </a>
            {% endfor %}
        </div>
    </section>
{% endif %}
