{% extends 'base.html.twig' %}

{% block title %}Mon panier - Fruits & Veggies{% endblock %}

{% block body %}
    <h1>Mon panier</h1>

    {% if items|length > 0 %}
        <div class="cart-items">
            <table>
                <thead>
                    <tr>
                        <th>Produit</th>
                        <th>Prix unitaire</th>
                        <th>Quantité</th>
                        <th>Total</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in items %}
                        {% include 'cart/_product_row.html.twig' with { item: item } %}
                    {% endfor %}
                </tbody>
            </table>

            <div class="cart-summary">
                <p class="cart-total"><strong>Total :</strong> {{ total|format_currency('EUR') }}</p>

                <form method="post" action="{{ path('app_cart_clear') }}" onsubmit="return confirm('Vider le panier ?');">
                    <button type="submit" class="btn btn-danger">Vider le panier</button>
                </form>
            </div>
        </div>
    {% else %}
        <p>Votre panier est vide.</p>
        <a href="{{ path('app_home') }}" class="btn">Découvrir nos produits</a>
    {% endif %}
{% endblock %}
