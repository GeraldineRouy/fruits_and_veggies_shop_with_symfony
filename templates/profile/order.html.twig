{% extends 'base.html.twig' %}

{% block title %}Commande #{{ order.id }} - Fruits & Veggies{% endblock %}

{% block body %}
    <h1>Commande #{{ order.id }}</h1>

    <p><strong>Date :</strong> {{ order.orderedAt|date('d/m/Y H:i') }}</p>
    <p><strong>Statut :</strong> <span class="badge badge-{{ order.status.value }}">{{ status_label }}</span></p>

    <table>
        <thead>
            <tr>
                <th>Produit</th>
                <th>Prix unitaire</th>
                <th>Quantité</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            {% for line in order.orderLines %}
                <tr>
                    <td>{{ line.product.name }}</td>
                    <td>{{ line.price|format_currency('EUR') }}</td>
                    <td>{{ line.quantity }}</td>
                    <td>{{ (line.price * line.quantity)|format_currency('EUR') }}</td>
                </tr>
            {% endfor %}
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3"><strong>Total :</strong></td>
                <td><strong>{{ total|format_currency('EUR') }}</strong></td>
            </tr>
        </tfoot>
    </table>

    {% if order.status.value == 'confirmed' %}
        <form method="post" action="{{ path('app_order_cancel', {id: order.id}) }}" onsubmit="return confirm('Annuler cette commande ?');">
            <button type="submit" class="btn btn-danger">Annuler la commande</button>
        </form>
    {% elseif order.status.value == 'cancelled' %}
        <p>Cette commande a été annulée.</p>
    {% elseif order.status.value == 'delivered' %}
        <p>Cette commande a été livrée. Merci de votre confiance !</p>
    {% endif %}

    <a href="{{ path('app_order_list') }}">← Retour à mes commandes</a>
{% endblock %}
